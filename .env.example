# ========== Agent Configuration ==========
ANTHROPIC_API_KEY=sk-ant-...
AGENT_LOCATION=Remote

# ========== Google OAuth (Sign in with Google) ==========
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ========== Deployment (override auto-detected URLs) ==========
# Set this to your public URL for proper OAuth redirect URIs
# Example: https://your-app.com
APP_URL=http://localhost:8080

# ========== Session Security ==========
# Set a fixed secret key to persist sessions across restarts
DASHBOARD_SECRET_KEY=your-secure-random-secret-here

# ========== Data Directory (where logs, CVs, and DB are stored) ==========
DATA_DIR=.

# ========== Resend Email (password reset emails) ==========
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@your-domain.com
